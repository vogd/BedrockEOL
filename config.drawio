        <mxCell id="50" value="✅ No per-account authorization needed. Organization aggregator automatically&lt;br&gt;has access to all member accounts. Just pick accounts from the list or use AllAwsRegions:true." style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;fontStyle=2;fontColor=#2D7600;" vertex="1" parent="1">
          <mxGeometry x="200" y="600" width="560" height="40" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
